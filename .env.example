# PostgreSQL (used by the db container)
POSTGRES_DB=lifemanager
POSTGRES_USER=lifemanager
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# .NET API — connection string (host=db matches the Docker Compose service name)
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=lifemanager;Username=lifemanager;Password=CHANGE_ME_STRONG_PASSWORD

# JWT — generate a random 32+ char secret
Jwt__Secret=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG
Jwt__Issuer=lifemanager
Jwt__Audience=lifemanager-users

# Google OAuth (from Google Cloud Console)
Google__ClientId=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
Google__ClientSecret=YOUR_GOOGLE_CLIENT_SECRET

# CORS — your Lovable frontend URL (no trailing slash)
AllowedOrigins=https://your-app.lovable.app

# Docker image — replace USERNAME with your GitHub username
GHCR_IMAGE=ghcr.io/USERNAME/lifemanager-api:latest
